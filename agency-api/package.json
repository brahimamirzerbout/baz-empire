{
  "name": "agency-api",
  "version": "1.0.0",
  "description": "Secure REST API for the Agency Directory — 24 marketing, media & advertising agency types.",
  "private": true,
  "type": "commonjs",
  "engines": { "node": ">=18" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:domain": "tsx prisma/seed-domain.ts",
    "seed:all": "tsx prisma/seed.ts && tsx prisma/seed-domain.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "generate": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test:services": "tsx tests/services.test.ts",
    "build": "tsc",
    "serve": "node dist/index.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "prisma": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}