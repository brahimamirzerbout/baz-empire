# ── Agency API environment ──────────────────────────────
# Copy to .env and adjust as needed.

# HTTP port the server listens on
PORT=4000

# SQLite database file (relative to project root). SQLite needs the
# `file:` prefix for Prisma.
DATABASE_URL="file:./data/agency.db"

# Comma-separated list of allowed CORS origins. Use * to allow all
# (fine for development; lock down in production).
CORS_ORIGIN="*"

# Node environment
NODE_ENV=development

# Optional: protect write endpoints (POST/PUT/DELETE) with a shared
# admin API key. Leave empty to disable. Send as header: X-Api-Key.
ADMIN_API_KEY=
