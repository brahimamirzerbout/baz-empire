{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BAZ Marketing Hub",
  "version": "0.1.0",
  "identifier": "com.baz.marketinghub",
  "build": {
    "beforeDevCommand": "curl -sf http://localhost:3000 >/dev/null 2>&1 || (cd /home/uzer/marketing-hub && pnpm dev)",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": null,
    "frontendDist": "https://marketing-hub-roan.vercel.app"
  },
  "app": {
    "windows": [
      {
        "title": "BAZ Marketing Hub",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://marketing-hub-roan.vercel.app; style-src 'self' 'unsafe-inline' https://marketing-hub-roan.vercel.app; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://marketing-hub-roan.vercel.app https://*.vercel.app https://*.supabase.co wss://*.supabase.co; media-src 'self' https:; frame-src 'self' https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self' https://marketing-hub-roan.vercel.app"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1N0E0MUY0RjEyMjA4MkQKUldRdENDTHg5RUY2NWNseDdaMktFbWE2c083b3RBamZEeWV0Rk9rMlhMdUdVKzhrQnIxNXRxUXEK",
      "endpoints": [
        "https://marketing-hub-roan.vercel.app/updater/latest.json"
      ]
    }
  }
}