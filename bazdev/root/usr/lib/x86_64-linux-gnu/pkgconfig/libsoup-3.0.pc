prefix=/home/uzer/bazdev/root/usr
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu

exec_prefix=${prefix}

Name: libsoup
Description: A glib-based HTTP library
Version: 3.6.5
Requires: glib-2.0 >=  2.70.0, gmodule-no-export-2.0 >=  2.70.0, gobject-2.0 >=  2.70.0, gio-2.0 >=  2.70.0
Requires.private: sysprof-capture-4, sqlite3, libpsl >=  0.20, libbrotlidec, krb5-gssapi, zlib, libnghttp2
Libs: -L${libdir} -lsoup-3.0
Cflags: -I${includedir}/libsoup-3.0
