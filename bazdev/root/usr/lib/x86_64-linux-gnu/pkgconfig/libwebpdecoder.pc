prefix=/home/uzer/bazdev/root/usr
exec_prefix=${prefix}
libdir=${exec_prefix}/lib/x86_64-linux-gnu
includedir=${prefix}/include

Name: libwebpdecoder
Description: Library for the WebP graphics format (decode only)
Version: 1.5.0
Cflags: -I${includedir}
Libs: -L${libdir} -lwebpdecoder
Libs.private: -lm  
