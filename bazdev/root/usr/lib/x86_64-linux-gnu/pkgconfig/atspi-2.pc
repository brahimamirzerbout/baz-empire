prefix=/home/uzer/bazdev/root/usr
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu

Name: atspi
Description: Accessibility Technology software library
Version: 2.56.2
Requires: dbus-1 >=  1.5, glib-2.0 >=  2.67.4
Requires.private: gobject-2.0 >=  2.0.0, gio-2.0 >=  2.28.0, x11, xtst, xi
Libs: -L${libdir} -latspi
Cflags: -I${includedir}/at-spi-2.0
