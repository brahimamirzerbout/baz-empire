prefix=/home/uzer/bazdev/root/usr
exec_prefix=${prefix}
libdir=${exec_prefix}/lib/x86_64-linux-gnu
includedir=${prefix}/include

Name: libwebp
Description: Library for the WebP graphics format
Version: 1.5.0
Requires.private: libsharpyuv
Cflags: -I${includedir}
Libs: -L${libdir} -lwebp
Libs.private: -lm  
