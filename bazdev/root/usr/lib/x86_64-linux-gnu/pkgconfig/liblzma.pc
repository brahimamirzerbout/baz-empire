prefix=/home/uzer/bazdev/root/usr
exec_prefix=/home/uzer/bazdev/root/usr
libdir=/home/uzer/bazdev/root/usr/lib/x86_64-linux-gnu
includedir=/home/uzer/bazdev/root/usr/include

Name: liblzma
Description: General purpose data compression library
URL: https://tukaani.org/xz/
Version: 5.8.1
Cflags: -I${includedir}
Cflags.private: -DLZMA_API_STATIC
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread 
