# Client size multipliers (ÆTHER pricing philosophy: transparent, no hidden fees)
CLIENT_MULTIPLIERS = {
    "micro": 0.8,     # Solo entrepreneur — on baisse le prix
    "smb": 1.0,       # Standard pricing
    "enterprise": 1.3, # Larger organizations — légèrement plus cher
}

def calculate_pricing(args):
    service = PRICING.get(args.service)
    if not service:
        print(f"Unknown service: {args.service}")
        return

    scope = service["scopes"].get(args.scope)
    if not scope:
        print(f"Unknown scope: {args.scope}")
        print(f"Available scopes: {', '.join(service['scopes'].keys())}")
        return

    multiplier = CLIENT_MULTIPLIERS.get(args.client, 1.0)
    base_price = scope["price"]
    adjusted_price = int(base_price * multiplier)
    retainer = int(service["retainer"] * multiplier)

    print("\n" + "=" * 60)
    print(f"  ⚡ ÆTHER — DEVIS")
    print("=" * 60)
    print(f"\n  Service:    {service['name']}")
    print(f"  Tagline:    {service['tagline']}")
    print(f"  Client:     {args.client.upper()}")
    print(f"  Scope:      {scope['label']}")
    print(f"  Delivery:   {scope['delivery']}")
    print(f"\n  ┌─────────────────────────────────────────────┐")
    print(f"  │  ONE-TIME:   {adjusted_price:>10,} DA               │")
    if retainer:
        print(f"  │  RETAINER:   {retainer:>10,} DA/mois            │")
    print(f"  └─────────────────────────────────────────────┘")
    print(f"\n  Retainer inclut:")
    print(f"    • {service['retainer_includes']}")
    print(f"\n  ⚡ Avantage concurrentiel:")
    print(f"    {service['competitive_delta']}")

    # Bundle suggestions
    if args.service == "aether-qr":
        print(f"\n  📦 Upsell Suggestions:")
        print(f"    • QR → ÆTHER Social:  +10 000 DA/mois")
        print(f"    • QR → ÆTHER Croissance:  25 000 DA/mois (best deal)")
    elif args.service == "aether-social":
        print(f"\n  📦 Upsell Suggestions:")
        print(f"    • Social + SEO:  20 000 DA/mois")
        print(f"    • ÆTHER Croissance (tout):  25 000 DA/mois")
    elif args.service != "aether-full":
        print(f"\n  📦 Best Deal: ÆTHER Croissance à 25 000 DA/mois — tout inclus.")

    print("=" * 60)

def list_services(args):
    print("\n" + "=" * 60)
    print("  ⚡ ÆTHER — SERVICES & TARIFS")
    print("=" * 60)
    for key, svc in PRICING.items():
        print(f"\n  {svc['name']}")
        print(f"  {svc['tagline']}")
        for scope, details in svc["scopes"].items():
            price_str = f"{details['price']:,} DA" if details['price'] > 0 else "GRATUIT"
            print(f"    {scope:>8s}: {details['label']:<45s} {price_str:>8s}")
        if svc["retainer"]:
            print(f"    Retainer: {svc['retainer']:,} DA/mois — {svc['retainer_includes']}")
        print(f"    ⚡ {svc['competitive_delta']}")
    print("\n" + "=" * 60)

def main():
    parser = argparse.ArgumentParser(description="ÆTHER Pricing Calculator")
    subparsers = parser.add_subparsers(dest="command")

    calc_p = subparsers.add_parser("calc", help="Calculate pricing for a service")
    calc_p.add_argument("--service", "-s", required=True, choices=PRICING.keys())
    calc_p.add_argument("--scope", choices=["free", "starter", "growth", "medium", "full", "croissance", "premium", "enterprise"], default="starter")
    calc_p.add_argument("--client", "-c", choices=CLIENT_MULTIPLIERS.keys(), default="smb")

    subparsers.add_parser("list", help="List all services and pricing")

    args = parser.parse_args()
    if args.command == "calc":
        calculate_pricing(args)
    elif args.command == "list":
        list_services(args)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()