def generate_posts(topic_key="qr", platform="instagram", count=5):
    """Generate ÆTHER-branded social media posts."""
    topic = AETHER_TOPICS.get(topic_key, topic_key)
    tmpl = TEMPLATES.get(platform, TEMPLATES["instagram"])
    posts = []

    for i in range(count):
        hook = random.choice(tmpl["hooks"]).format(topic=topic)
        cta = random.choice(tmpl["ctas"])

        # Build bilingual hashtags
        hashtags = set()
        for pool_name, pool in tmpl["hashtag_pools"].items():
            hashtags.update(random.sample(pool, min(3, len(pool))))

        # ÆTHER brand voice rules
        post = {
            "platform": platform,
            "topic_key": topic_key,
            "topic": topic,
            "hook": hook,
            "body_fr": f"{hook}\n\n{cta}",
            "body_ar": "",  # Arabic version placeholder
            "hashtags": " ".join(sorted(hashtags)[:8]),
            "best_time": get_best_time(platform),
            "visual_direction": get_visual_direction(platform),
        }

        # Generate Arabic version for key platforms
        if platform in ["instagram", "facebook"]:
            post["body_ar"] = generate_arabic(hook, cta, topic_key)

        posts.append(post)

    return posts

def generate_arabic(hook, cta, topic_key):
    """Generate Darija/Arabic version of posts."""
    ar_variants = {
        "qr": "قائمة QR مجانية — لا وكالة أخرى تقدمها",
        "pricing": "أسعارنا معلنة — 1 من 27 وكالة تعلن أسعارها",
        "speed": "تسليم في 24 ساعة — لا 2-4 أسابيع",
