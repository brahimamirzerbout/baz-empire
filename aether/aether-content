        "free": "مجاناً — ابدأ بدون دفع شيء",
    }
    ar_topic = ar_variants.get(topic_key, "")
    if ar_topic:
        return f"🇩🇿 {ar_topic}\n\n💬 فيريسونا على واتساب"
    return ""

def get_best_time(platform):
    """Best posting times for Algeria."""
    times = {
        "instagram": "12-14h, 19-21h (Sam-Jeu)",
        "facebook": "9-11h, 17-19h (Sam-Jeu)",
        "tiktok": "20-23h (Ven-Sam)",
        "linkedin": "8-10h, 14-16h (Dim-Mer)",
    }
    return times.get(platform, "9-11h en semaine")

def get_visual_direction(platform):
    """Visual direction for each platform."""
    directions = {
        "instagram": "Dark bg (#0F0A1E), Aether gradient accent, Æ ligature, QR code visual, stat number prominent",
        "facebook": "Dark bg, gradient overlay, clear price in DA, US Tech badge",
        "tiktok": "Full-screen QR scan animation, text overlay, 15s max",
        "linkedin": "Data visualization, 27 agencies analyzed stat, professional chart",
    }
    return directions.get(platform, "Dark bg, Aether brand colors")

def content_calendar(topic_key="qr", days=7):
    """Generate a week-long ÆTHER content calendar."""
    platforms = ["instagram", "facebook", "tiktok", "linkedin"]
    calendar = []

    for day in range(days):
        date = (datetime.now() + timedelta(days=day)).strftime("%Y-%m-%d")
        weekday = (datetime.now() + timedelta(days=day)).strftime("%A")
        # Rotate topics
        topics = list(AETHER_TOPICS.keys())
        day_topic = topics[(day + len(calendar)) % len(topics)]
        platform = platforms[day % len(platforms)]
        posts = generate_posts(day_topic, platform, count=1)

        calendar.append({
            "date": date,
            "day": weekday,
            "platform": platform,
            "topic": day_topic,
            "post_fr": posts[0]["body_fr"],
            "post_ar": posts[0].get("body_ar", ""),
            "hashtags": posts[0]["hashtags"],
            "best_time": posts[0]["best_time"],
            "visual": posts[0]["visual_direction"],
        })

    return calendar

def main():
    parser = argparse.ArgumentParser(description="ÆTHER Content Generator")
    parser.add_argument("topic", nargs="?", default="qr",
                       help=f"Topic key: {', '.join(AETHER_TOPICS.keys())} or free text")
    parser.add_argument("--platform", "-p", choices=PLATFORMS, default="instagram")
    parser.add_argument("--count", "-n", type=int, default=5)
    parser.add_argument("--calendar", "-c", action="store_true", help="Generate weekly calendar")
    parser.add_argument("--all", "-a", action="store_true", help="Generate for all platforms")
    parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    args = parser.parse_args()

    topic_key = args.topic if args.topic in AETHER_TOPICS else "qr"

    if args.calendar:
        cal = content_calendar(topic_key)
        if args.json:
            print(json.dumps(cal, indent=2, ensure_ascii=False))
        else:
            print(f"\n📅 ÆTHER WEEKLY CONTENT CALENDAR: {AETHER_TOPICS.get(topic_key, topic_key).upper()}")
            print("=" * 70)
            for entry in cal:
                print(f"\n  {entry['day']} ({entry['date']})")
                print(f"  Platform: {entry['platform'].upper()}")
                print(f"  Topic: {entry['topic']}")
                print(f"  FR: {entry['post_fr'][:80]}...")
                if entry['post_ar']:
                    print(f"  AR: {entry['post_ar'][:60]}...")
                print(f"  Tags: {entry['hashtags']}")
                print(f"  ⏰ Best time: {entry['best_time']}")
                print(f"  🎨 Visual: {entry['visual'][:60]}...")
            print()
        return

    platforms = PLATFORMS if args.all else [args.platform]

    for platform in platforms:
        posts = generate_posts(topic_key, platform, args.count)

        if args.json:
            print(json.dumps(posts, indent=2, ensure_ascii=False))
        else:
            topic = AETHER_TOPICS.get(topic_key, topic_key)
            print(f"\n⚡ ÆTHER — {platform.upper()} POSTS: {topic}")
            print("-" * 55)
            for i, post in enumerate(posts, 1):
                print(f"\n  Post #{i}")
                print(f"  {post['body_fr']}")
                if post.get('body_ar'):
                    print(f"  🇩🇿 {post['body_ar']}")
                print(f"  {post['hashtags']}")
                print(f"  ⏰ Best time: {post['best_time']}")
                print(f"  🎨 Visual: {post['visual_direction'][:50]}...")

if __name__ == "__main__":
    main()